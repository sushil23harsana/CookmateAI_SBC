# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Provider: "mock" (default, works offline) or "swiggy" (live Instamart MCP) ---
COOKMATE_PROVIDER=mock

# --- Swiggy Instamart MCP (only needed when COOKMATE_PROVIDER=swiggy) ---
SWIGGY_MCP_URL=https://mcp.swiggy.com/im
# Phase 0 shortcut: paste a bearer token from the Builders Club console.
# Full OAuth 2.1 PKCE flow is stubbed in src/instamart/swiggyMcp.ts.
SWIGGY_MCP_TOKEN=
# Optional: override discovered tool names if the regex resolver guesses wrong.
# SWIGGY_TOOL_SEARCH=
# SWIGGY_TOOL_ORDER=
# SWIGGY_TOOL_TRACK=

# --- Model ---
COOKMATE_MODEL=claude-opus-4-8

# --- Pricing / guardrails ---
COOKMATE_DELIVERY_FEE=35
COOKMATE_MIN_ORDER_VALUE=99
COOKMATE_MAX_ORDER_VALUE=5000
COOKMATE_PANTRY_FILE=./data/pantry.json

# --- Resilience ---
COOKMATE_MAX_TOOL_ITERATIONS=24
COOKMATE_REQUEST_TIMEOUT_MS=60000
COOKMATE_MAX_RETRIES=3

# --- Logging: debug | info | warn | error (logs go to stderr) ---
LOG_LEVEL=info

# --- Server hardening (API) ---
PORT=8787
# Comma-separated allowlist of origins the browser app is served from.
CORS_ORIGIN=http://localhost:3000
# Per-IP requests/minute on /api/* (protects your Anthropic bill from abuse).
RATE_LIMIT_PER_MIN=30
# Max characters accepted in a single chat message.
MESSAGE_MAX_CHARS=2000
# Idle session time-to-live (ms) before eviction, and a hard cap on live sessions.
SESSION_TTL_MS=1800000
MAX_SESSIONS=1000
# Set to true ONLY when deployed behind a trusted reverse proxy / load balancer,
# so the rate limiter keys on the real client IP from X-Forwarded-For.
# Leave false when the API is exposed directly (XFF is client-forgeable).
TRUST_PROXY=false
